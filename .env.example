# Server-only. For Vercel, use Supabase's pooled connection string for serverless functions.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Optional browser-safe values if you later add a direct Supabase client in the frontend.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Server-only. Never expose in client code or PUBLIC_* env vars.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CTA_BUS_TRACKER_API_KEY=your-cta-api-key
CTA_BUS_TRACKER_POLL_INTERVAL_SEC=45
CTA_BUS_TRACKER_BATCH_SIZE=6
CTA_BUS_TRACKER_LOW_TIER_MAX_STALENESS_SEC=360
CTA_BUS_TRACKER_ACTIVITY_TTL_SEC=360
CTA_BUS_TRACKER_ROUTE_REFRESH_SEC=900
# Worker-only when publishing a separate serving database.
SERVING_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Optional route override for debugging only:
# CTA_BUS_TRACKER_ROUTES=1,2,3
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
MAPBOX_TOKEN=optional
